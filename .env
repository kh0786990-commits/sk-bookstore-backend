PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=db.wgegykvifzmtiqemnhud.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=BookStoryPass123!

# JWT Configuration
JWT_SECRET=skbookstore_super_secret_jwt_key_2024_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=skbookstore_refresh_token_secret_key_2024
JWT_REFRESH_EXPIRE=30d

# Admin Configuration
ADMIN_EMAIL=admin@skbookstore.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=S.K Admin

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Email Configuration (Gmail/SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@skbookstore.com

# Frontend URL
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3001

# File Upload
MAX_FILE_SIZE=50mb
ALLOWED_FILE_TYPES=.pdf,.epub,.mobi,.txt,.docx,.doc,.fb2,.rtf

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Payment Settings
CURRENCY=usd
PAYMENT_PROCESSOR=stripe

# Analytics
ENABLE_ANALYTICS=true
GOOGLE_ANALYTICS_ID=your_ga_id

# Book Store Settings
ENABLE_PURCHASES=false
ENABLE_FREE_BOOKS=true
ENABLE_SUBSCRIPTIONS=false
